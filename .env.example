AEGIS_ENVIRONMENT=development
AEGIS_LOG_LEVEL=INFO
AEGIS_HTTP_ADDRESS=:8080
AEGIS_SHUTDOWN_TIMEOUT=20s
AEGIS_READ_HEADER_TIMEOUT=5s
AEGIS_READ_TIMEOUT=15s
AEGIS_WRITE_TIMEOUT=30s
AEGIS_IDLE_TIMEOUT=60s
AEGIS_MAX_HEADER_BYTES=1048576
AEGIS_DATABASE_URL=postgres://aegis:aegis@postgres:5432/aegis?sslmode=disable
AEGIS_REDIS_ADDRESS=redis:6379
AEGIS_KAFKA_BROKERS=kafka:9092
AEGIS_RABBITMQ_URL=amqp://aegis:aegis@rabbitmq:5672/
AEGIS_API_KEY_PEPPER=development-only-pepper-change-me-32-bytes
AEGIS_DEV_API_KEY=aegis_devkey0000_0123456789abcdefghijklmnopqrstuvwxyzABCDEFG
AEGIS_DEV_MEMORY=false
AEGIS_PROVIDER_NAME=mock-primary
AEGIS_PROVIDER_ENDPOINT=http://mock-provider:8080
AEGIS_PROVIDER_MODELS=aegis-small,aegis-medium
AEGIS_ROUTING_STRATEGY=weighted_round_robin
AEGIS_KAFKA_TOPIC=aegis.events.v1
AEGIS_KAFKA_CONSUMER_GROUP=aegis-audit-v1
AEGIS_OTLP_ENDPOINT=otel-collector:4318
AEGIS_MAX_BODY_BYTES=1048576
AEGIS_WORKER_CONCURRENCY=4
